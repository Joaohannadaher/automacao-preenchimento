# CONFIGURAÇÃO DE AUTENTICAÇÃO - SharePoint
# Copie este arquivo para .env e preencha com seus dados

# Opção 1: Autenticação Azure AD (RECOMENDADO)
# Crie uma aplicação no Azure AD para obter CLIENT_ID e CLIENT_SECRET
AZURE_CLIENT_ID=seu-client-id-aqui
AZURE_CLIENT_SECRET=seu-client-secret-aqui

# Opção 2: Autenticação Básica (Usuário/Senha)
# Menos seguro, use apenas para desenvolvimento/teste
SHAREPOINT_USERNAME=seu-usuario@suaempresa.com.br
SHAREPOINT_PASSWORD=sua-senha-aqui

# URL do site SharePoint
SHAREPOINT_SITE_URL=https://suaempresa.sharepoint.com/sites/SeuSite

# Intervalo de execução (em segundos)
INTERVALO_SEGUNDOS=60

# Emails para notificação de erro (separados por vírgula)
EMAILS_NOTIFICACAO=admin@suaempresa.com.br
